// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// database definitions
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   // "PATIENT" or "THERAPIST"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patient   PatientProfile?
  therapist TherapistProfile?
}

model PatientProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  fullName       String
  dateOfBirth    DateTime
  phoneNumber    String
  medicalHistory String?
  currentPain    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  treatmentPlans  TreatmentPlan[]  @relation("PatientTreatmentPlans")
  workoutSessions WorkoutSession[] @relation("PatientWorkoutSessions")
  appointments    Appointment[]    @relation("PatientAppointments")
  payments        Payment[]
  feedback        SessionFeedback[]
}

model TherapistProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  fullName      String
  licenseNumber String   @unique
  specialty     String?
  yearsOfExperience Int?
  bio           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  treatmentPlans   TreatmentPlan[]    @relation("TherapistTreatmentPlans")
  appointments     Appointment[]      @relation("TherapistAppointments")
  availabilitySlots AvailabilitySlot[]
  feedback         SessionFeedback[]
}

model TreatmentPlan {
  id          String    @id @default(cuid())
  title       String
  description String?
  patientId   String
  therapistId String
  status      String    @default("ACTIVE") // "ACTIVE", "COMPLETED", "PAUSED"
  startDate   DateTime  @default(now())
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  patient   PatientProfile      @relation("PatientTreatmentPlans", fields: [patientId], references: [id], onDelete: Cascade)
  therapist TherapistProfile    @relation("TherapistTreatmentPlans", fields: [therapistId], references: [id], onDelete: Cascade)
  exercises PrescribedExercise[]
}

model PrescribedExercise {
  id              String    @id @default(cuid())
  planId          String
  name            String
  description     String?
  targetSets      Int
  targetReps      Int
  restSeconds     Int
  frequencyPerWeek Int      @default(3)
  videoUrl        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  plan     TreatmentPlan    @relation(fields: [planId], references: [id], onDelete: Cascade)
  sessions WorkoutSession[]
}

model WorkoutSession {
  id                String    @id @default(cuid())
  patientId         String
  exerciseId        String
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  setsCompleted     Int?
  repsCompleted     Int?
  durationSeconds   Int?
  patientNotes      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  patient   PatientProfile     @relation("PatientWorkoutSessions", fields: [patientId], references: [id], onDelete: Cascade)
  exercise  PrescribedExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  painLogs  PainLog[]
}

model PainLog {
  id             String   @id @default(cuid())
  sessionId      String
  score          Int      // 0 to 10
  timing         String   // "PRE" or "POST"
  bodyLocation   String?  // optional, "left knee", "lower back", etc.
  createdAt      DateTime @default(now())

  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Appointment {
  id            String    @id @default(cuid())
  patientId     String
  therapistId   String
  scheduledFor  DateTime
  durationMinutes Int     @default(30)
  status        String    @default("SCHEDULED") // "SCHEDULED", "COMPLETED", "CANCELLED", "NO_SHOW"
  videoRoomUrl  String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient   PatientProfile   @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  therapist TherapistProfile @relation("TherapistAppointments", fields: [therapistId], references: [id], onDelete: Cascade)
  payment   Payment?
  feedback  SessionFeedback?
}

model AvailabilitySlot {
  id           String   @id @default(cuid())
  therapistId  String
  dayOfWeek    Int      // 0 = Sunday, 6 = Saturday
  startTime    String   // "09:00"
  endTime      String   // "10:00"
  isRecurring  Boolean  @default(true)
  specificDate DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  therapist TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

model Payment {
  id             String   @id @default(cuid())
  patientId      String
  appointmentId  String   @unique
  amount         Float
  currency       String   @default("RWF")
  paymentMethod  String   @default("MOMO") // "MOMO", "CARD"
  momoReference  String?
  status         String   @default("PENDING") // "PENDING", "COMPLETED", "FAILED", "REFUNDED"
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model SessionFeedback {
  id            String   @id @default(cuid())
  patientId     String
  therapistId   String
  appointmentId String   @unique
  rating        Int      // 1 to 5
  comment       String?
  createdAt     DateTime @default(now())

  patient     PatientProfile   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  therapist   TherapistProfile @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  appointment Appointment      @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}
